#!/usr/bin/env nu

def main [to_open: string] {
    mut params = $to_open | url parse | get params | transpose --header-row;
    
    let clion_pid = pidof clion | complete;
    
    if $clion_pid.exit_code != 0 {
        notify-send --app-name="pycharm:// handler" --icon="open-link" "PyCharm is not running, opening with default app";
	    start "$file";
	    return;
    }
    
    if not "file" in $params {
        return;
    }
    
    if not "line" in $params {
        $params = $params | insert "line" 1;
    }
    
    ~/.local/binaries/pycharm-community/bin/pycharm --line $params.line $params.file;
}
